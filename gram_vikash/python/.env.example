# GramVikash Python Service Configuration

# Groq API Key (required for LLM features)
GROQ_API_KEY=your-groq-api-key-here

# Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GROQ_MODEL=llama-3.1-70b-versatile

# Custom Image Classifier (EfficientNet-B0 trained on Colab)
# Place model.pth and class_names.json in python/model/
# Or override the paths below:
# MODEL_WEIGHTS_PATH=python/model/model.pth
# CLASS_NAMES_PATH=python/model/class_names.json

# RAG Settings
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.5

# Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
